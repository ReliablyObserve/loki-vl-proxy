{
  "annotations": {
    "list": []
  },
  "description": "Loki-VL-proxy operations dashboard — request quality, query-range recovery, connection stickiness, HTTP/1.x rotation visibility, and fleet cache health for long-lived Grafana/Loki-compatible clients.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Overview",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false
    },
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 1},
      "targets": [
        {
          "expr": "sum(rate(loki_vl_proxy_requests_total{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"}[$__rate_interval])) by (endpoint)",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"fillOpacity": 10}}
      }
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 1},
      "targets": [
        {
          "expr": "sum(rate(loki_vl_proxy_requests_total{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\",status=~\"4..|5..\"}[$__rate_interval])) by (endpoint, status)",
          "legendFormat": "{{endpoint}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"fillOpacity": 10}, "color": {"mode": "palette-classic"}}
      }
    },
    {
      "title": "Error Percentage",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
      "targets": [
        {
          "expr": "100 * sum(rate(loki_vl_proxy_requests_total{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\",status=~\"5..\"}[$__rate_interval])) / sum(rate(loki_vl_proxy_requests_total{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"}[$__rate_interval]))",
          "legendFormat": "5xx %"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "percent", "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]}}
      }
    },
    {
      "title": "Uptime (Youngest Pod)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 1},
      "targets": [
        {
          "expr": "min(loki_vl_proxy_uptime_seconds{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"}) or vector(0)",
          "legendFormat": "youngest uptime"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"}
      }
    },
    {
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 5},
      "targets": [
        {
          "expr": "(100 * sum(rate(loki_vl_proxy_cache_hits_total{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"}[$__rate_interval])) / clamp_min(sum(rate(loki_vl_proxy_cache_hits_total{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"}[$__rate_interval])) + sum(rate(loki_vl_proxy_cache_misses_total{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"}[$__rate_interval])), 0.000001)) or vector(0)",
          "legendFormat": "cluster hit %"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "percent", "min": 0, "max": 100,
          "thresholds": {"steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 50}, {"color": "green", "value": 80}]}}
      }
    },
    {
      "title": "Translation Errors",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 5},
      "targets": [
        {
          "expr": "sum(rate(loki_vl_proxy_translation_errors_total{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"}[$__rate_interval])) or vector(0)",
          "legendFormat": "cluster errors/s"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "red", "value": 0.1}]}}
      }
    },
    {
      "title": "Latency",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "collapsed": false
    },
    {
      "title": "Downstream P50 Latency by Endpoint",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(loki_vl_proxy_request_duration_seconds_bucket{system=\"loki\",direction=\"downstream\",job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"}[$__rate_interval])) by (endpoint, le))",
          "legendFormat": "p50 {{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s", "custom": {"fillOpacity": 10}}
      }
    },
    {
      "title": "Downstream P99 Latency by Endpoint",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(loki_vl_proxy_request_duration_seconds_bucket{system=\"loki\",direction=\"downstream\",job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"}[$__rate_interval])) by (endpoint, le))",
          "legendFormat": "p99 {{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s", "custom": {"fillOpacity": 10}}
      }
    },
    {
      "title": "Cache",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "collapsed": false
    },
    {
      "title": "Cache Hits vs Misses",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "targets": [
        {
          "expr": "sum(rate(loki_vl_proxy_cache_hits_total{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"}[$__rate_interval])) or vector(0)",
          "legendFormat": "hits/s"
        },
        {
          "expr": "sum(rate(loki_vl_proxy_cache_misses_total{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"}[$__rate_interval])) or vector(0)",
          "legendFormat": "misses/s"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"fillOpacity": 10}}
      }
    },
    {
      "title": "Translations",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 19},
      "targets": [
        {
          "expr": "sum(rate(loki_vl_proxy_translations_total{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"}[$__rate_interval])) or vector(0)",
          "legendFormat": "translations/s"
        },
        {
          "expr": "sum(rate(loki_vl_proxy_translation_errors_total{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"}[$__rate_interval])) or vector(0)",
          "legendFormat": "errors/s"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"fillOpacity": 10}}
      }
    },
    {
      "title": "Request Breakdown",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27},
      "collapsed": false
    },
    {
      "title": "Requests by Endpoint",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 28},
      "targets": [
        {
          "expr": "sum(increase(loki_vl_proxy_requests_total{system=\"loki\",direction=\"downstream\",job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"}[$__range])) by (endpoint)",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "title": "Requests by Status Code",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 28},
      "targets": [
        {
          "expr": "sum(increase(loki_vl_proxy_requests_total{system=\"loki\",direction=\"downstream\",job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"}[$__range])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "title": "Avg Latency by Endpoint",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 28},
      "targets": [
        {
          "expr": "sum(rate(loki_vl_proxy_request_duration_seconds_sum{system=\"loki\",direction=\"downstream\",job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"}[$__rate_interval])) by (endpoint) / sum(rate(loki_vl_proxy_request_duration_seconds_count{system=\"loki\",direction=\"downstream\",job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"}[$__rate_interval])) by (endpoint)",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"}
      }
    },
    {
      "title": "Tenants",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 36},
      "collapsed": false
    },
    {
      "title": "Request Rate by Tenant",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 37},
      "targets": [
        {
          "expr": "sum(rate(loki_vl_proxy_tenant_requests_total{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"}[$__rate_interval])) by (tenant)",
          "legendFormat": "{{tenant}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"fillOpacity": 10}}
      }
    },
    {
      "title": "Tenant P99 Latency",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 37},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(loki_vl_proxy_tenant_request_duration_seconds_bucket{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"}[$__rate_interval])) by (tenant, le))",
          "legendFormat": "p99 {{tenant}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s", "custom": {"fillOpacity": 10}}
      }
    },
    {
      "title": "Tenant Error Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 45},
      "targets": [
        {
          "expr": "sum(rate(loki_vl_proxy_tenant_requests_total{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\",status=~\"5..\"}[$__rate_interval])) by (tenant)",
          "legendFormat": "5xx {{tenant}}"
        },
        {
          "expr": "sum(rate(loki_vl_proxy_tenant_requests_total{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\",status=~\"4..\"}[$__rate_interval])) by (tenant)",
          "legendFormat": "4xx {{tenant}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"fillOpacity": 10}}
      }
    },
    {
      "title": "Client Errors by Reason",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 45},
      "targets": [
        {
          "expr": "sum(rate(loki_vl_proxy_client_errors_total{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"}[$__rate_interval])) by (endpoint, reason)",
          "legendFormat": "{{endpoint}}/{{reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"fillOpacity": 10}}
      }
    },
    {
      "title": "Top Tenants by Request Volume",
      "type": "table",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 53},
      "targets": [
        {
          "expr": "topk(10, sum(increase(loki_vl_proxy_tenant_requests_total{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"}[$__range])) by (tenant))",
          "legendFormat": "{{tenant}}",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "title": "Top Tenants by Latency",
      "type": "table",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 53},
      "targets": [
        {
          "expr": "topk(10, sum(rate(loki_vl_proxy_tenant_request_duration_seconds_sum{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"}[$__rate_interval])) by (tenant) / sum(rate(loki_vl_proxy_tenant_request_duration_seconds_count{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"}[$__rate_interval])) by (tenant))",
          "legendFormat": "{{tenant}}",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"}
      }
    },
    {
      "title": "Process Resources & Runtime",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 61},
      "collapsed": false
    },
    {
      "title": "CPU Saturation by Pod",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 62},
      "targets": [
        {
          "expr": "sum(max by (pod, mode) (loki_vl_proxy_process_cpu_usage_ratio{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"})) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {"fillOpacity": 10},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.6},
              {"color": "red", "value": 0.85}
            ]
          }
        }
      }
    },
    {
      "title": "Memory Usage Ratio by Pod",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 62},
      "targets": [
        {
          "expr": "max by (pod) (loki_vl_proxy_process_memory_usage_ratio{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"})",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {"fillOpacity": 10},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.7},
              {"color": "red", "value": 0.85}
            ]
          }
        }
      }
    },
    {
      "title": "Memory Footprint by Pod",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 62},
      "targets": [
        {
          "expr": "max by (pod) (loki_vl_proxy_process_resident_memory_bytes{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"})",
          "legendFormat": "{{pod}} rss"
        },
        {
          "expr": "max by (pod) (loki_vl_proxy_go_memstats_alloc_bytes{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"})",
          "legendFormat": "{{pod}} alloc"
        },
        {
          "expr": "max by (pod) (loki_vl_proxy_go_memstats_heap_inuse_bytes{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"})",
          "legendFormat": "{{pod}} heap inuse"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {"fillOpacity": 10}
        }
      }
    },
    {
      "title": "Goroutines by Pod",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 62},
      "targets": [
        {
          "expr": "max by (pod) (loki_vl_proxy_go_goroutines{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"})",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"fillOpacity": 10}}
      }
    },
    {
      "title": "GC Cycles / s by Pod",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 70},
      "targets": [
        {
          "expr": "sum by (pod) (rate(loki_vl_proxy_go_gc_cycles_total{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"}[$__rate_interval]))",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "ops", "custom": {"fillOpacity": 10}}
      }
    },
    {
      "title": "Open File Descriptors by Pod",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 70},
      "targets": [
        {
          "expr": "max by (pod) (loki_vl_proxy_process_open_fds{job=~\"${job:regex}|${job:regex}-headless\",cluster=~\"${cluster:regex}\",env=~\"${env:regex}\",namespace=~\"${namespace:regex}|loki-vl-proxy\",service=~\"${service:regex}|${service:regex}-headless|\",pod=~\"${pod:regex}\"})",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "none", "custom": {"fillOpacity": 10}}
      }
    },
    {
      "title": "PSI Pressure (60s) by Pod",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 70},
      "targets": [
        {
