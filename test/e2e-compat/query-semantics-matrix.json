      "family": "binary_vector",
      "endpoint": "query_range",
      "query": "sum by (app, pod) (count_over_time({cluster=\"us-east-1\"}[5m])) * on(app) group_left(level) sum by (app, level) (count_over_time({cluster=\"us-east-1\", level=\"error\"}[5m]))",
      "step": "60",
