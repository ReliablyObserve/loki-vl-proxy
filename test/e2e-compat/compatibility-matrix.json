        "v1.46.0",
        "v1.47.0",
        "v1.48.0",
        "v1.49.0",
        "v1.50.0"
      ],
    "capability_profiles": [
      {
        "profile": "vl-v1.50-plus",
        "version_range": ">= v1.50.0",
        "capabilities": [
          "stream_metadata_endpoints",
          "dense_patterns_windowing",
