{
  "stack": {
    "loki": {
      "image_repo": "grafana/loki",
      "pinned_version": "3.7.1",
      "support_window": {
        "policy": "current_minor_plus_previous_minor",
        "description": "Support the current Loki minor family and one minor family behind. Keep all patch releases in the supported families, and slide the window forward when a new minor becomes current.",
        "current_family": "3.7.x",
        "previous_family": "3.6.x"
      },
      "matrix_versions": [
        "3.6.0",
        "3.6.1",
        "3.6.2",
        "3.6.3",
        "3.6.4",
        "3.6.5",
        "3.6.6",
        "3.6.7",
        "3.6.8",
        "3.6.9",
        "3.6.10",
        "3.7.0",
        "3.7.1"
      ],
      "role": "reference implementation"
    },
    "victorialogs": {
      "image_repo": "victoriametrics/victoria-logs",
      "pinned_version": "v1.49.0",
      "support_window": {
        "policy": "v1_3x_and_v1_4x",
        "description": "Support VictoriaLogs releases in the v1.3x.x and v1.4x.x bands. This is intentionally broader than Loki because users commonly run older VictoriaLogs backends during migration windows.",
        "current_family": "v1.4x.x",
        "previous_family": "v1.3x.x"
      },
      "matrix_versions": [
        "v1.30.0",
        "v1.31.0",
        "v1.32.0",
        "v1.33.0",
        "v1.34.0",
        "v1.35.0",
        "v1.36.0",
        "v1.37.0",
        "v1.38.0",
        "v1.39.0",
        "v1.40.0",
        "v1.41.0",
        "v1.42.0",
        "v1.43.0",
        "v1.44.0",
        "v1.45.0",
        "v1.46.0",
        "v1.47.0",
        "v1.48.0",
        "v1.49.0"
      ],
      "role": "backend under translation"
    },
    "grafana": {
      "image_repo": "grafana/grafana",
      "pinned_version": "12.4.2",
      "role": "runtime hosting the Loki datasource and bundled Drilldown app",
      "support_window": {
        "policy": "latest_full_plus_current_and_previous_smoke",
        "description": "Run the fuller Drilldown compatibility track on the pinned current Grafana family, and keep smaller current-family and previous-family datasource-plus-Drilldown smoke profiles on pull requests so browser/runtime regressions are caught across real Grafana builds without exploding cost.",
        "current_family": "12.x",
        "previous_family": "11.x"
      },
      "runtime_profiles": [
        {
          "version": "12.4.2",
          "profile": "full",
          "test_regex": "^(TestDrilldownTrackScore|TestDrilldown_RuntimeFamilyContracts)$"
        },
        {
          "version": "12.4.1",
          "profile": "current_smoke",
          "run_on_pr": true,
          "test_regex": "^(TestGrafanaDatasourceCatalogAndHealth|TestDrilldown_GrafanaResourceContracts|TestDrilldown_RuntimeFamilyContracts)$"
        },
        {
          "version": "11.6.6",
          "profile": "previous_smoke",
          "run_on_pr": true,
          "test_regex": "^(TestGrafanaDatasourceCatalogAndHealth|TestDrilldown_GrafanaResourceContracts|TestDrilldown_RuntimeFamilyContracts)$"
        }
      ]
    },
    "logs_drilldown_contract": {
      "repo": "https://github.com/grafana/logs-drilldown",
      "pinned_version": "2.0.1",
      "pinned_commit": "4463f56047de75da95251086d1906fb902ad53a7",
      "support_window": {
        "policy": "current_family_plus_previous_family",
        "description": "Support the current Logs Drilldown release family and one family behind. The contract matrix moves forward as upstream releases advance; we do not keep an open-ended history of older families.",
        "current_family": "2.0.x",
        "previous_family": "1.0.x"
      },
      "matrix_versions": [
        "2.0.1",
        "2.0.0",
        "1.0.41",
        "1.0.40",
        "1.0.39",
        "1.0.38",
        "1.0.37",
        "1.0.36",
        "1.0.35",
        "1.0.34"
      ],
      "notes": [
        "Service selection uses index/volume on the primary label",
        "Service detail logs use a mixed parser selector: json + logfmt + drop __error__ stages",
        "detected_fields is post-processed by the app datasource wrapper to drop detected_level, level, and level_extracted",
        "Patterns are label-scoped; parsed fields, metadata, and line filters are not expected to constrain the pattern list"
      ]
    }
  },
  "tracks": {
    "loki": {
      "workflow": "compat-loki.yaml",
      "score_test": "TestLokiTrackScore",
      "runtime_matrix": true,
      "edge_cases": [
